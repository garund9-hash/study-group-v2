rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only the owner can read or write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Study groups: public read; only the organizer can create/update/delete
    match /studyGroups/{studyId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.organizerId == request.auth.uid
        && request.resource.data.title.size() <= 100
        && request.resource.data.description.size() <= 2000;
      allow update, delete: if request.auth != null
        && resource.data.organizerId == request.auth.uid;
    }

    // Applications: applicant can create their own; organizer of the study can read and update status only
    match /applications/{appId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid
          || get(/databases/$(database)/documents/studyGroups/$(resource.data.studyId)).data.organizerId == request.auth.uid);
      allow update: if request.auth != null
        && get(/databases/$(database)/documents/studyGroups/$(resource.data.studyId)).data.organizerId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);
    }
  }
}
